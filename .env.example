# Copy this file to .env and fill in values for your environment.
# .env is gitignored; .env.example is committed as a template.
# Existing shell env vars take precedence over .env values.

# --- Service ---
PORT=8080
LOG_LEVEL=info          # one of: trace, debug, info, warn, error, fatal
NODE_ENV=development    # development | production

# --- ClickHouse (read-only upstream: hl-ingest's ClickHouse) ---
# Reach it over the tailnet via the HTTP interface on :8123.
# The native :9000 protocol is loopback-only on the hl-ingest box, so HTTP it is.
# Example (the hl-ingest box's tailnet IP): http://100.x.y.z:8123
CH_URL=
CH_DATABASE=hl
CH_USERNAME=default
CH_PASSWORD=
# Optional: which dex to read from hl-ingest (it ingests the equity-perp "xyz" dex).
CH_DEX=

# --- Supabase (server-side; service role bypasses RLS) ---
# Leave blank to run the public read tier only; the auth bridge stays dormant
# (auth routes return 503 auth_not_configured) until these are set.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
# The Supabase JWT secret — used to MINT app sessions the Supabase client can use
# under RLS. Find it in Supabase: Project Settings -> API -> JWT Settings.
SUPABASE_JWT_SECRET=
# TTL (seconds) for minted Supabase session JWTs.
SESSION_JWT_TTL_SECONDS=3600

# --- Hyperliquid EU proxy (geo-block bypass; same proxy used by hl-ingest) ---
HL_PROXY_URL=
HL_PROXY_KEY=

# --- Benzinga (earnings calendar, EPS estimates + actuals, confirmed times) ---
# Chosen over Finnhub/FMP because it provides HH:MM:SS time precision
# with a date_confirmed flag. Contact Benzinga sales for API key + pricing.
BENZINGA_API_KEY=

# --- Privy (auth provider; wired in a later pass) ---
# Leave blank for now. When present, the auth bridge verifies Privy access tokens
# and mints Supabase sessions. PRIVY_VERIFICATION_KEY is the app's public
# verification key (Privy Dashboard -> App settings -> JWT verification key).
PRIVY_APP_ID=
PRIVY_VERIFICATION_KEY=
