{
  "info": {
    "_postman_id": "hl-api-0000-0000-0000-000000000001",
    "name": "hl-api",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Test collection for the hl-api service.\n\nSet the `baseUrl` variable (default http://localhost:8080). For the Account folder, paste a Privy access token into `privyToken` — those routes return 503 auth_not_configured until Privy env is set.\n\nWhat works when:\n- Ops (health/readyz/metrics): always.\n- Market (sample/perp/candles): once CH_PASSWORD is set (reads hl-ingest's ClickHouse over the tailnet).\n- Assets (list/detail): once Supabase creds are set AND the assets/earnings tables are seeded.\n- Account (session/profile/portfolio/positions): once Privy is wired."
  },
  "item": [
    {
      "name": "Ops",
      "item": [
        {
          "name": "Health (liveness)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/healthz", "host": ["{{baseUrl}}"], "path": ["healthz"] },
            "description": "200 {\"status\":\"ok\"} if the process is up."
          }
        },
        {
          "name": "Readiness (checks ClickHouse)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/readyz", "host": ["{{baseUrl}}"], "path": ["readyz"] },
            "description": "200 when ClickHouse is reachable; reports auth-bridge state. 503 if CH unreachable."
          }
        },
        {
          "name": "Metrics (Prometheus)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/metrics", "host": ["{{baseUrl}}"], "path": ["metrics"] },
            "description": "Prometheus exposition format."
          }
        }
      ]
    },
    {
      "name": "Market (public)",
      "item": [
        {
          "name": "Markets browse (merged: price + name + logo + 24h)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/markets?limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "markets"],
              "query": [
                { "key": "limit", "value": "50" },
                { "key": "dex", "value": "xyz", "disabled": true }
              ]
            },
            "description": "The browse/markets list: all live coins with mark price, day volume, 24h change, plus name/logo where the asset is catalogued. Works even before assets is seeded (name/logo just come back null)."
          }
        },
        {
          "name": "Market sample (raw ClickHouse feed)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/market/sample?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "market", "sample"],
              "query": [
                { "key": "limit", "value": "10" },
                { "key": "coin", "value": "AAPL", "disabled": true },
                { "key": "dex", "value": "xyz", "disabled": true }
              ]
            },
            "description": "Latest snapshot per coin from asset_ctx, newest-volume first."
          }
        },
        {
          "name": "Perp detail (mark/leverage/price-change)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/market/perp/{{coin}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "market", "perp", "{{coin}}"]
            },
            "description": "Mark price (not oracle), max leverage, price change over 1h/1d/7d/30d."
          }
        },
        {
          "name": "Perp candles (chart)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// default window: last 7 days, unix seconds",
                  "pm.collectionVariables.set('from', Math.floor(Date.now() / 1000) - 7 * 24 * 3600);",
                  "pm.collectionVariables.set('to', Math.floor(Date.now() / 1000));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/market/perp/{{coin}}/candles?interval=1h&from={{from}}&to={{to}}&limit=200",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "market", "perp", "{{coin}}", "candles"],
              "query": [
                { "key": "interval", "value": "1h" },
                { "key": "from", "value": "{{from}}" },
                { "key": "to", "value": "{{to}}" },
                { "key": "limit", "value": "200" }
              ]
            },
            "description": "OHLCV candles. interval one of 1m,5m,15m,1h,4h,1d. from/to are unix seconds (auto-set by the pre-request script to the last 7 days)."
          }
        }
      ]
    },
    {
      "name": "Assets (public)",
      "item": [
        {
          "name": "Assets list",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/assets?limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "assets"],
              "query": [
                { "key": "limit", "value": "50" },
                { "key": "offset", "value": "0", "disabled": true },
                { "key": "dex", "value": "xyz", "disabled": true }
              ]
            },
            "description": "Paginated asset catalog."
          }
        },
        {
          "name": "Asset detail (the asset page)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/assets/{{ticker}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "assets", "{{ticker}}"]
            },
            "description": "Aggregated asset page: metadata + next earnings + expected EPS + beat odds + past earnings + mark price. 404 until the assets/earnings tables are seeded."
          }
        }
      ]
    },
    {
      "name": "Account (auth — Privy bearer)",
      "item": [
        {
          "name": "Auth session (mint Supabase JWT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const t = pm.response.json().supabaseAccessToken;",
                  "  if (t) { pm.collectionVariables.set('supabaseToken', t); console.log('captured supabaseToken'); }",
                  "} else {",
                  "  console.log('auth not available:', pm.response.code, pm.response.text());",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{privyToken}}" }],
            "url": { "raw": "{{baseUrl}}/v1/auth/session", "host": ["{{baseUrl}}"], "path": ["v1", "auth", "session"] },
            "description": "Verify the Privy token, mint a Supabase session JWT. On 200, the test script stores it in `supabaseToken`. 503 auth_not_configured until Privy env is set."
          }
        },
        {
          "name": "Profile (identity + lazy create)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{privyToken}}" }],
            "url": { "raw": "{{baseUrl}}/v1/profile", "host": ["{{baseUrl}}"], "path": ["v1", "profile"] },
            "description": "Verified id + wallet; lazily upserts the profile row. 503 until Privy wired; 401 without a token."
          }
        },
        {
          "name": "Portfolio (account value + positions)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{privyToken}}" }],
            "url": { "raw": "{{baseUrl}}/v1/portfolio", "host": ["{{baseUrl}}"], "path": ["v1", "portfolio"] },
            "description": "Live HL account value/cash/positions + 24h change. Needs Privy + HL_PROXY_KEY + a wallet on the profile."
          }
        },
        {
          "name": "Positions closed",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{privyToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/v1/positions/closed?days=30",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "positions", "closed"],
              "query": [{ "key": "days", "value": "30" }]
            },
            "description": "Closed positions (realized PnL, open/close time) from HL fills. days max 90."
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "coin", "value": "AAPL" },
    { "key": "ticker", "value": "AAPL" },
    { "key": "privyToken", "value": "" },
    { "key": "supabaseToken", "value": "" },
    { "key": "from", "value": "" },
    { "key": "to", "value": "" }
  ]
}
