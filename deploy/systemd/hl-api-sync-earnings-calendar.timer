# Tier A (discovery): full earnings calendar sync (90-day horizon). Daily.
# Joins on the (manually-seeded) assets table for the ticker list.
[Unit]
Description=hl-api: daily earnings calendar sync

[Timer]
OnCalendar=*-*-* 08:15:00 UTC
OnBootSec=2min
Persistent=true
Unit=hl-api-job@sync-earnings-calendar.service

[Install]
WantedBy=timers.target
